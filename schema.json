{
    "$schema": "https://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string",
        },
        "words": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "names": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "minItems": 1
                    },
                    "replacement": {
                        "type": "string"
                    }
                },
                "required": [
                    "names",
                    "replacement"
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "words"
    ],
    "additionalProperties": false
}
